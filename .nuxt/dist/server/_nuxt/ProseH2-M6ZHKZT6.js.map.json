{"file":"ProseH2-M6ZHKZT6.js","mappings":";;;;;;;;;;;EAcA,MAAM,QAAQ;EAGd,MAAM,EAAE,aAAa,iBAAiB,CAAC,CAAC,OAAO;EAC/C,MAAM,YAAA,GAAA,YAAA,SAAA,OAA0B,MAAM,OAAO,OAAO,UAAU,gBAAgB,aAAa,UAAU,gBAAgB,QAAQ,OAAO,UAAU,gBAAgB,YAAY,UAAU,aAAa,GAAG;;yFAjB7L,IAAI,MAAM,GAAA,GAAA,MAAA,CAAA,EAAA,EAAA;OAEL,MAAM,OAAA,GAAA,YAAA,MAAA,CAAM,QAAA,GAAQ;0DACzB,QAAI,IAAM,MAAM,IAAE,EAAA,EAAA","names":[],"sources":["../../../../node_modules/.pnpm/@nuxtjs+mdc@0.22.2_magic-st_47ab540253be9c51e23a440077b6be9c/node_modules/@nuxtjs/mdc/dist/runtime/components/prose/ProseH2.vue"],"sourcesContent":["<template>\n  <h2 :id=\"props.id\">\n    <a\n      v-if=\"props.id && generate\"\n      :href=\"`#${props.id}`\"\n    >\n      <slot />\n    </a>\n    <slot v-else />\n  </h2>\n</template>\n\n<script setup>\nimport { computed, useRuntimeConfig } from \"#imports\";\nconst props = defineProps({\n  id: { type: String, required: false }\n});\nconst { headings } = useRuntimeConfig().public.mdc;\nconst generate = computed(() => props.id && (typeof headings?.anchorLinks === \"boolean\" && headings?.anchorLinks === true || typeof headings?.anchorLinks === \"object\" && headings?.anchorLinks?.h2));\n</script>\n"],"version":3}