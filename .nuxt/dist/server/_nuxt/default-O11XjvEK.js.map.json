dark')\n\nfunction toggleDark() {\n  colorMode.preference = colorMode.value === 'dark' ? 'light' : 'dark'\n}\n</script>\n","<template>\n  <button\n    class=\"p-1.5 rounded-md text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors\"\n    :aria-label=\"isDark ? '切换到亮色模式' : '切换到暗色模式'\"\n    @click=\"toggleDark\"\n  >\n    <Sun v-if=\"isDark\" class=\"w-4 h-4\" />\n    <Moon v-else class=\"w-4 h-4\" />\n  </button>\n</template>\n\n<script setup lang=\"ts\">\nimport { Sun, Moon } from 'lucide-vue-next'\n\nconst colorMode = useColorMode()\n\nconst isDark = computed(() => colorMode.value === 'dark')\n\nfunction toggleDark() {\n  colorMode.preference = colorMode.value === 'dark' ? 'light' : 'dark'\n}\n</script>\n","export const useSearchStore = () => {\n  const isOpen = ref(false)\n\n  function open() {\n    isOpen.value = true\n  }\n\n  function close() {\n    isOpen.value = false\n  }\n\n  function toggle() {\n    isOpen.value = !isOpen.value\n  }\n\n  return {\n    isOpen: readonly(isOpen),\n    open,\n    close,\n    toggle,\n  }\n}\n","<template>\n  <header class=\"sticky top-0 z-40 border-b border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg))/80] backdrop-blur-sm\">\n    <nav class=\"max-w-5xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between\">\n      <NuxtLink to=\"/\" class=\"text-lg font-bold tracking-tight\">\n        CodexList\n      </NuxtLink>\n\n      <div class=\"flex items-center gap-3\">\n        <NuxtLink\n          to=\"/tags\"\n          class=\"text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 transition-colors\"\n        >\n          标签\n        </NuxtLink>\n        <NuxtLink\n          to=\"/about\"\n          class=\"text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 transition-colors\"\n        >\n          关于\n        </NuxtLink>\n\n        <button\n          class=\"p-1.5 rounded-md text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors\"\n          aria-label=\"搜索\"\n          @click=\"searchStore.open()\"\n        >\n          <Search class=\"w-4 h-4\" />\n        </button>\n\n        <ThemeToggle />\n      </div>\n    </nav>\n  </header>\n</template>\n\n<script setup lang=\"ts\">\nimport { Search } from 'lucide-vue-next'\n\nconst searchStore = useSearchStore()\n</script>\n","<template>\n  <header class=\"sticky top-0 z-40 border-b border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg))/80] backdrop-blur-sm\">\n    <nav class=\"max-w-5xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between\">\n      <NuxtLink to=\"/\" class=\"text-lg font-bold tracking-tight\">\n        CodexList\n      </NuxtLink>\n\n      <div class=\"flex items-center gap-3\">\n        <NuxtLink\n          to=\"/tags\"\n          class=\"text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 transition-colors\"\n        >\n          标签\n        </NuxtLink>\n        <NuxtLink\n          to=\"/about\"\n          class=\"text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 transition-colors\"\n        >\n          关于\n        </NuxtLink>\n\n        <button\n          class=\"p-1.5 rounded-md text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors\"\n          aria-label=\"搜索\"\n          @click=\"searchStore.open()\"\n        >\n          <Search class=\"w-4 h-4\" />\n        </button>\n\n        <ThemeToggle />\n      </div>\n    </nav>\n  </header>\n</template>\n\n<script setup lang=\"ts\">\nimport { Search } from 'lucide-vue-next'\n\nconst searchStore = useSearchStore()\n</script>\n","<template>\n  <footer class=\"border-t border-[rgb(var(--color-border))] mt-16\">\n    <div class=\"max-w-5xl mx-auto px-4 sm:px-6 py-8\">\n      <div class=\"flex flex-col sm:flex-row items-center justify-between gap-4\">\n        <p class=\"text-sm text-gray-500 dark:text-gray-400\">\n          &copy; {{ new Date().getFullYear() }} CodexList. All rights reserved.\n        </p>\n        <div class=\"flex items-center gap-4 text-sm text-gray-500 dark:text-gray-400\">\n          <NuxtLink to=\"/\" class=\"hover:text-gray-900 dark:hover:text-gray-100 transition-colors\">\n            首页\n          </NuxtLink>\n          <NuxtLink to=\"/tags\" class=\"hover:text-gray-900 dark:hover:text-gray-100 transition-colors\">\n            标签\n          </NuxtLink>\n          <NuxtLink to=\"/about\" class=\"hover:text-gray-900 dark:hover:text-gray-100 transition-colors\">\n            关于\n          </NuxtLink>\n        </div>\n      </div>\n    </div>\n  </footer>\n</template>\n","<template>\n  <Teleport to=\"body\">\n    <div\n      v-if=\"searchStore.isOpen\"\n      class=\"fixed inset-0 z-50 flex items-start justify-center pt-[15vh]\"\n      @click.self=\"searchStore.close()\"\n    >\n      <div class=\"absolute inset-0 bg-black/40 backdrop-blur-sm\" @click=\"searchStore.close()\" />\n\n      <div class=\"relative w-full max-w-lg mx-4 bg-[rgb(var(--color-bg))] border border-[rgb(var(--color-border))] rounded-xl shadow-2xl overflow-hidden\">\n        <!-- Search input -->\n        <div class=\"flex items-center gap-3 px-4 border-b border-[rgb(var(--color-border))]\">\n          <Search class=\"w-4 h-4 text-gray-400 flex-shrink-0\" />\n          <input\n            ref=\"input\"\n            v-model=\"query\"\n            type=\"text\"\n            placeholder=\"搜索文章...\"\n            class=\"flex-1 py-3.5 bg-transparent text-sm outline-none placeholder:text-gray-400\"\n            @keydown.escape=\"searchStore.close()\"\n          >\n          <kbd class=\"hidden sm:inline-flex items-center px-1.5 py-0.5 text-xs text-gray-400 bg-gray-100 dark:bg-gray-800 rounded\">\n            ESC\n          </kbd>\n        </div>\n\n        <!-- Results -->\n        <div v-if=\"query\" class=\"max-h-80 overflow-y-auto\">\n          <div v-if=\"loading\" class=\"flex items-center justify-center py-8\">\n            <div class=\"w-5 h-5 border-2 border-blue-500 border-t-transparent rounded-full animate-spin\" />\n          </div>\n\n          <div v-else-if=\"results.length === 0\" class=\"py-8 text-center text-sm text-gray-500 dark:text-gray-400\">\n            没有找到相关内容\n          </div>\n\n          <NuxtLink\n            v-for=\"result in results\"\n            :key=\"result.path\"\n            :to=\"`/articles/${result.path}`\"\n            class=\"block px-4 py-3 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors\"\n            @click=\"searchStore.close()\"\n          >\n            <p class=\"text-sm font-medium\">{{ result.title }}</p>\n            <p v-if=\"result.description\" class=\"text-xs text-gray-500 dark:text-gray-400 mt-0.5 line-clamp-1\">\n              {{ result.description }}\n            </p>\n          </NuxtLink>\n        </div>\n\n        <!-- Empty state -->\n        <div v-else class=\"py-8 text-center text-sm text-gray-500 dark:text-gray-400\">\n          输入关键词开始搜索\n        </div>\n      </div>\n    </div>\n  </Teleport>\n</template>\n\n<script setup lang=\"ts\">\nimport { Search } from 'lucide-vue-next'\n\nconst searchStore = useSearchStore()\nconst input = ref<HTMLInputElement>()\nconst query = ref('')\nconst results = ref<Array<{ path: string; title: string; description?: string }>>([])\nconst loading = ref(false)\n\nwatch(query, async (q) => {\n  if (!q.trim()) {\n    results.value = []\n    return\n  }\n\n  loading.value = true\n  try {\n    const { data } = await useFetch('/api/search', {\n      params: { q: q.trim() },\n    })\n    if (data.value) {\n      results.value = data.value as Array<{ path: string; title: string; description?: string }>\n    }\n  } catch {\n    results.value = []\n  } finally {\n    loading.value = false\n  }\n}, { debounce: 200 })\n\nonMounted(() => {\n  // Keyboard shortcut\n  useEventListener('keydown', (e: KeyboardEvent) => {\n    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {\n      e.preventDefault()\n      searchStore.toggle()\n      if (searchStore.isOpen) {\n        nextTick(() => input.value?.focus())\n      }\n    }\n    if (e.key === 'Escape' && searchStore.isOpen) {\n      searchStore.close()\n    }\n  })\n})\n\nwatch(() => searchStore.isOpen, (open) => {\n  if (open) {\n    nextTick(() => {\n      input.value?.focus()\n      query.value = ''\n      results.value = []\n    })\n  }\n})\n</script>\n","<template>\n  <Teleport to=\"body\">\n    <div\n      v-if=\"searchStore.isOpen\"\n      class=\"fixed inset-0 z-50 flex items-start justify-center pt-[15vh]\"\n      @click.self=\"searchStore.close()\"\n    >\n      <div class=\"absolute inset-0 bg-black/40 backdrop-blur-sm\" @click=\"searchStore.close()\" />\n\n      <div class=\"relative w-full max-w-lg mx-4 bg-[rgb(var(--color-bg))] border border-[rgb(var(--color-border))] rounded-xl shadow-2xl overflow-hidden\">\n        <!-- Search input -->\n        <div class=\"flex items-center gap-3 px-4 border-b border-[rgb(var(--color-border))]\">\n          <Search class=\"w-4 h-4 text-gray-400 flex-shrink-0\" />\n          <input\n            ref=\"input\"\n            v-model=\"query\"\n            type=\"text\"\n            placeholder=\"搜索文章...\"\n            class=\"flex-1 py-3.5 bg-transparent text-sm outline-none placeholder:text-gray-400\"\n            @keydown.escape=\"searchStore.close()\"\n          >\n          <kbd class=\"hidden sm:inline-flex items-center px-1.5 py-0.5 text-xs text-gray-400 bg-gray-100 dark:bg-gray-800 rounded\">\n            ESC\n          </kbd>\n        </div>\n\n        <!-- Results -->\n        <div v-if=\"query\" class=\"max-h-80 overflow-y-auto\">\n          <div v-if=\"loading\" class=\"flex items-center justify-center py-8\">\n            <div class=\"w-5 h-5 border-2 border-blue-500 border-t-transparent rounded-full animate-spin\" />\n          </div>\n\n          <div v-else-if=\"results.length === 0\" class=\"py-8 text-center text-sm text-gray-500 dark:text-gray-400\">\n            没有找到相关内容\n          </div>\n\n          <NuxtLink\n            v-for=\"result in results\"\n            :key=\"result.path\"\n            :to=\"`/articles/${result.path}`\"\n            class=\"block px-4 py-3 hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors\"\n            @click=\"searchStore.close()\"\n          >\n            <p class=\"text-sm font-medium\">{{ result.title }}</p>\n            <p v-if=\"result.description\" class=\"text-xs text-gray-500 dark:text-gray-400 mt-0.5 line-clamp-1\">\n              {{ result.description }}\n            </p>\n          </NuxtLink>\n        </div>\n\n        <!-- Empty state -->\n        <div v-else class=\"py-8 text-center text-sm text-gray-500 dark:text-gray-400\">\n          输入关键词开始搜索\n        </div>\n      </div>\n    </div>\n  </Teleport>\n</template>\n\n<script setup lang=\"ts\">\nimport { Search } from 'lucide-vue-next'\n\nconst searchStore = useSearchStore()\nconst input = ref<HTMLInputElement>()\nconst query = ref('')\nconst results = ref<Array<{ path: string; title: string; description?: string }>>([])\nconst loading = ref(false)\n\nwatch(query, async (q) => {\n  if (!q.trim()) {\n    results.value = []\n    return\n  }\n\n  loading.value = true\n  try {\n    const { data } = await useFetch('/api/search', {\n      params: { q: q.trim() },\n    })\n    if (data.value) {\n      results.value = data.value as Array<{ path: string; title: string; description?: string }>\n    }\n  } catch {\n    results.value = []\n  } finally {\n    loading.value = false\n  }\n}, { debounce: 200 })\n\nonMounted(() => {\n  // Keyboard shortcut\n  useEventListener('keydown', (e: KeyboardEvent) => {\n    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {\n      e.preventDefault()\n      searchStore.toggle()\n      if (searchStore.isOpen) {\n        nextTick(() => input.value?.focus())\n      }\n    }\n    if (e.key === 'Escape' && searchStore.isOpen) {\n      searchStore.close()\n    }\n  })\n})\n\nwatch(() => searchStore.isOpen, (open) => {\n  if (open) {\n    nextTick(() => {\n      input.value?.focus()\n      query.value = ''\n      results.value = []\n    })\n  }\n})\n</script>\n","<template>\n  <div class=\"min-h-screen flex flex-col\">\n    <BlogHeader />\n    <main class=\"flex-1\">\n      <slot />\n    </main>\n    <BlogFooter />\n    <SearchModal />\n  </div>\n</template>\n\n<script setup lang=\"ts\">\n</script>\n"],"version":3}