items-center justify-center gap-2 mt-8\">\n      <button\n        :disabled=\"currentPage === 1\"\n        class=\"px-3 py-1.5 text-sm rounded-md border border-[rgb(var(--color-border))] disabled:opacity-40 hover:bg-[rgb(var(--color-card))] transition-colors\"\n        @click=\"currentPage = Math.max(1, currentPage - 1)\"\n      >\n        上一页\n      </button>\n      <span class=\"text-sm text-gray-500 dark:text-gray-400\">\n        {{ currentPage }} / {{ totalPages }}\n      </span>\n      <button\n        :disabled=\"currentPage === totalPages\"\n        class=\"px-3 py-1.5 text-sm rounded-md border border-[rgb(var(--color-border))] disabled:opacity-40 hover:bg-[rgb(var(--color-card))] transition-colors\"\n        @click=\"currentPage = Math.min(totalPages, currentPage + 1)\"\n      >\n        下一页\n      </button>\n    </nav>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\nuseHead({\n  title: '首页',\n})\n\nconst { data: articles, pending } = await useAsyncData('articles-list', () =>\n  queryCollection('articles')\n    .select(['title', 'description', 'path', 'date', 'tags'])\n    .all()\n)\n\nconst pageSize = 10\nconst currentPage = ref(1)\n\nconst totalPages = computed(() => Math.max(1, Math.ceil((articles.value?.length || 0) / pageSize)))\n\nconst paginatedArticles = computed(() => {\n  if (!articles.value) return []\n  const start = (currentPage.value - 1) * pageSize\n  return articles.value.slice(start, start + pageSize)\n})\n\nwatch(currentPage, () => {\n  window.scrollTo({ top: 0, behavior: 'smooth' })\n})\n</script>\n","<template>\n  <div class=\"max-w-5xl mx-auto px-4 sm:px-6 py-8\">\n    <!-- Hero -->\n    <div class=\"mb-10\">\n      <h1 class=\"text-3xl font-bold mb-2\">CodexList</h1>\n      <p class=\"text-gray-600 dark:text-gray-400\">记录技术思考与探索</p>\n    </div>\n\n    <!-- Articles list -->\n    <div v-if=\"articles.length === 0 && !pending\" class=\"text-center py-16 text-gray-500 dark:text-gray-400\">\n      暂无文章\n    </div>\n\n    <div v-else class=\"space-y-4\">\n      <ArticleCard\n        v-for=\"article in paginatedArticles\"\n        :key=\"article.path\"\n        :article=\"article\"\n      />\n    </div>\n\n    <!-- Pagination -->\n    <nav v-if=\"totalPages > 1\" class=\"flex items-center justify-center gap-2 mt-8\">\n      <button\n        :disabled=\"currentPage === 1\"\n        class=\"px-3 py-1.5 text-sm rounded-md border border-[rgb(var(--color-border))] disabled:opacity-40 hover:bg-[rgb(var(--color-card))] transition-colors\"\n        @click=\"currentPage = Math.max(1, currentPage - 1)\"\n      >\n        上一页\n      </button>\n      <span class=\"text-sm text-gray-500 dark:text-gray-400\">\n        {{ currentPage }} / {{ totalPages }}\n      </span>\n      <button\n        :disabled=\"currentPage === totalPages\"\n        class=\"px-3 py-1.5 text-sm rounded-md border border-[rgb(var(--color-border))] disabled:opacity-40 hover:bg-[rgb(var(--color-card))] transition-colors\"\n        @click=\"currentPage = Math.min(totalPages, currentPage + 1)\"\n      >\n        下一页\n      </button>\n    </nav>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\nuseHead({\n  title: '首页',\n})\n\nconst { data: articles, pending } = await useAsyncData('articles-list', () =>\n  queryCollection('articles')\n    .select(['title', 'description', 'path', 'date', 'tags'])\n    .all()\n)\n\nconst pageSize = 10\nconst currentPage = ref(1)\n\nconst totalPages = computed(() => Math.max(1, Math.ceil((articles.value?.length || 0) / pageSize)))\n\nconst paginatedArticles = computed(() => {\n  if (!articles.value) return []\n  const start = (currentPage.value - 1) * pageSize\n  return articles.value.slice(start, start + pageSize)\n})\n\nwatch(currentPage, () => {\n  window.scrollTo({ top: 0, behavior: 'smooth' })\n})\n</script>\n"],"version":3}